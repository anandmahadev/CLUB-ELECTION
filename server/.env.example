# =============================================
# COLLEGE ELECTION SYSTEM - Environment Config
# =============================================

# Server
PORT=5000
NODE_ENV=production

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=college_election
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# JWT Secrets
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_ADMIN_SECRET=your_super_secret_admin_jwt_key_change_this_in_production
JWT_EXPIRY=1h

# Admin Credentials (set once, stored in DB)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123

# CORS Origin (set to your frontend URL in production)
CLIENT_ORIGIN=http://localhost:5173
